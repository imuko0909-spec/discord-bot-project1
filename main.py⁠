import discord
from discord.ext import commands
import os
import asyncio

# 1. 共通の設定
intents = discord.Intents.all()
bot = commands.Bot(command_prefix="!", intents=intents)

# 自分のIDをここに設定してください
MY_USER_ID = 1232865763094827112
# 個室の受付チャンネルID
ENTRY_CHANNEL_ID=1521453980268498974

# --- 個室機能用 ---
rooms = {}

class ExtendButton(discord.ui.View):
    def __init__(self, channel):
        super().__init__(timeout=None)
        self.channel = channel

    @discord.ui.button(label="10分延長", style=discord.ButtonStyle.primary)
    async def extend(self, interaction: discord.Interaction, button: discord.ui.Button):
        rooms[self.channel.id] += 600
        await interaction.response.send_message("10分延長しました！", ephemeral=True)

async def manage_room_timer(channel):
    while rooms.get(channel.id, 0) > 0:
        await asyncio.sleep(60)
        rooms[channel.id] -= 60
        if rooms[channel.id] <= 0:
            await channel.send("時間終了です。部屋を削除します。")
            await channel.delete()
            del rooms[channel.id]
            break

# --- マイリスト機能用 ---
class ActionView(discord.ui.View):
    def __init__(self, target_member):
        super().__init__(timeout=60)
        self.target = target_member

    @discord.ui.button(label="❤️ お気に入り追加", style=discord.ButtonStyle.green)
    async def add_fav(self, interaction: discord.Interaction, button: discord.ui.Button):
        await interaction.response.send_message(f"{self.target.name} をお気に入りに入れました。", ephemeral=True)

    @discord.ui.button(label="🚫 BL追加", style=discord.ButtonStyle.danger)
    async def add_bl(self, interaction: discord.Interaction, button: discord.ui.Button):
        await interaction.response.send_message(f"{self.target.name} をブラックリストに入れました。", ephemeral=True)

class SelectMemberView(discord.ui.View):
    def __init__(self, guild):
        super().__init__(timeout=60)
        options = [discord.SelectOption(label=m.name, value=str(m.id)) for m in guild.members if not m.bot][:25]
        self.add_item(self.MemberSelect(options))

    class MemberSelect(discord.ui.Select):
        def __init__(self, options):
            super().__init__(placeholder="メンバーを選択...", options=options)
        async def callback(self, interaction: discord.Interaction):
            target = interaction.guild.get_member(int(self.values[0]))
            await interaction.response.send_message(f"{target.name} を選択しました。", view=ActionView(target), ephemeral=True)

# --- イベントとコマンド ---
@bot.event
async def on_ready():
    await bot.tree.sync()
    print("Botがログインしました！")

@bot.event
async def on_voice_state_update(member, before, after):
    if after.channel and after.channel.id == ENTRY_CHANNEL_ID:
        new_channel = await after.channel.guild.create_voice_channel(name=f"{member.name}の個室")
        await member.move_to(new_channel)
        rooms[new_channel.id] = 600
        await new_channel.send("個室へようこそ！", view=ExtendButton(new_channel))
        bot.loop.create_task(manage_room_timer(new_channel))
    if before.channel and before.channel.id in rooms and len(before.channel.members) == 0:
        await before.channel.delete()

@bot.tree.command(name="mylist", description="マイリスト管理")
async def mylist(interaction: discord.Interaction):
    if interaction.user.id != MY_USER_ID: return
    await interaction.response.send_message("メンバー選択：", view=SelectMemberView(interaction.guild), ephemeral=True)

bot.run(os.environ["TOKEN"])
@bot.tree.command(name="create_room", description="個室を新しく作成します")
async def create_room(interaction: discord.Interaction):
    category = interaction.user.voice.channel.category if interaction.user.voice and interaction.user.voice.channel else None
    new_channel = await interaction.guild.create_voice_channel(name=f"{interaction.user.name}の個室", category=category)
    rooms[new_channel.id] = 600
    await new_channel.send("個室へようこそ！", view=ExtendButton(new_channel))
    bot.loop.create_task(manage_room_timer(new_channel))
    await interaction.response.send_message("個室を作成しました。", ephemeral=True)

