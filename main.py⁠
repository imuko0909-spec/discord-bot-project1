import discord
from discord.ext import commands
import os
import asyncio

# インテントの設定
intents = discord.Intents.default()
intents.message_content = True
bot = commands.Bot(command_prefix="!", intents=intents)

# 個室のタイマー管理用
rooms = {}

# 延長ボタンのクラス
class ExtendButton(discord.ui.View):
    def __init__(self, channel):
        super().__init__(timeout=None)
        self.channel = channel

    @discord.ui.button(label="10分延長", style=discord.ButtonStyle.primary)
    async def extend(self, interaction: discord.Interaction, button: discord.ui.Button):
        rooms[self.channel.id] += 600
        await interaction.response.send_message("10分延長しました！", ephemeral=True)

# タイマー管理関数
async def manage_room_timer(channel):
    while channel.id in rooms:
        await asyncio.sleep(60)
        rooms[channel.id] -= 60
        if rooms[channel.id] <= 0:
            try:
                await channel.delete()
            except:
                pass
            if channel.id in rooms:
                del rooms[channel.id]
            break

# 起動時のログ
@bot.event
async def on_ready():
    print(f"ログイン完了: {bot.user}")
    print("Botは現在 !mylist と !vc_up を待機中です")

# コマンド：マイリスト
@bot.command(name="mylist")
async def mylist(ctx):
    await ctx.send("ここはマイリストです。")

# コマンド：!vc_up で個室作成
@bot.command(name="vc_up")
async def vc_up(ctx):
    category = ctx.author.voice.channel.category if ctx.author.voice and ctx.author.voice.channel else None
    new_channel = await ctx.guild.create_voice_channel(
        name=f"{ctx.author.name}の個室",
        category=category
    )
    rooms[new_channel.id] = 600
    await new_channel.send("個室へようこそ！", view=ExtendButton(new_channel))
    bot.loop.create_task(manage_room_timer(new_channel))
    await ctx.send(f"個室を作成しました: {new_channel.mention}")

# Bot起動
token = os.environ.get("TOKEN")
bot.run(token)
